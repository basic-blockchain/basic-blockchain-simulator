{
  "_postman_variable_scope": "environment",
  "name": "Blockchain Simulator — Local",
  "values": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000",
      "type": "default",
      "enabled": true,
      "description": "Base URL of the running Blockchain Simulator node"
    },
    {
      "key": "api_base",
      "value": "{{base_url}}/api/v1",
      "type": "default",
      "enabled": true,
      "description": "Versioned API root. All v1 endpoints use this prefix."
    },
    {
      "key": "username",
      "value": "alice",
      "type": "default",
      "enabled": true,
      "description": "Username used for auth requests"
    },
    {
      "key": "display_name",
      "value": "Alice",
      "type": "default",
      "enabled": true,
      "description": "Display name used at registration"
    },
    {
      "key": "email",
      "value": "alice@example.com",
      "type": "default",
      "enabled": true,
      "description": "Optional email for registration"
    },
    {
      "key": "password",
      "value": "hunter12345",
      "type": "default",
      "enabled": true,
      "description": "Password for activation/login (min 8 chars)"
    },
    {
      "key": "activation_code",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set by Register; used by Activate"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "JWT set by Login; used for Authorization header"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set by Register/Login"
    },
    {
      "key": "peer_url",
      "value": "http://127.0.0.1:5001",
      "type": "default",
      "enabled": true,
      "description": "URL of a second node instance for peer registration and consensus tests"
    },
    {
      "key": "sender",
      "value": "alice",
      "type": "default",
      "enabled": true,
      "description": "Default sender account identifier for transaction requests"
    },
    {
      "key": "receiver",
      "value": "bob",
      "type": "default",
      "enabled": true,
      "description": "Default receiver account identifier for transaction requests"
    },
    {
      "key": "amount",
      "value": "10.5",
      "type": "default",
      "enabled": true,
      "description": "Default transfer amount. Must be a positive number."
    },
    {
      "key": "wallet_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set by Create Wallet"
    },
    {
      "key": "wallet_public_key",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set by Create Wallet"
    },
    {
      "key": "receiver_wallet_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Destination wallet ID for signed transfers"
    },
    {
      "key": "transfer_amount",
      "value": "1.25",
      "type": "default",
      "enabled": true,
      "description": "Amount to send in a signed transfer"
    },
    {
      "key": "transfer_nonce",
      "value": "1",
      "type": "default",
      "enabled": true,
      "description": "Nonce for signed transfers (must increase per wallet)"
    },
    {
      "key": "transfer_signature",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Hex signature of the transfer payload (generated client-side)"
    },
    {
      "key": "admin_user_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Target user ID for admin actions"
    },
    {
      "key": "admin_wallet_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Target wallet ID for admin actions"
    },
    {
      "key": "admin_display_name",
      "value": "Alice Admin",
      "type": "default",
      "enabled": true,
      "description": "Display name used by Update User"
    },
    {
      "key": "admin_email",
      "value": "alice.admin@example.com",
      "type": "default",
      "enabled": true,
      "description": "Email used by Update User"
    },
    {
      "key": "role_name",
      "value": "OPERATOR",
      "type": "default",
      "enabled": true,
      "description": "Role name for grant/revoke role"
    },
    {
      "key": "permission_name",
      "value": "VIEW_WALLETS",
      "type": "default",
      "enabled": true,
      "description": "Permission name for grant/revoke permission"
    },
    {
      "key": "mint_amount",
      "value": "25",
      "type": "default",
      "enabled": true,
      "description": "Amount for admin mint"
    },
    {
      "key": "last_block_index",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set by the Mine Block request. Holds the index of the most recently mined block."
    },
    {
      "key": "last_proof",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set by the Mine Block request. Holds the proof of the most recently mined block."
    },
    {
      "key": "chain_length",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set by the Get Chain request. Holds the current chain length."
    },
    {
      "key": "pending_tx_count",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set by the Get Pending Transactions request."
    },
    {
      "key": "chain_is_valid",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set by the Validate Chain request. Boolean string."
    },
    {
      "key": "consensus_replaced",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-set by the Resolve Consensus request. true if chain was replaced."
    }
  ]
}
